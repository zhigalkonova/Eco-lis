rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Visits Collection (Analytics Logs)
    match /visits/{visitId} {
      allow create: if request.resource.data.id == visitId;
      allow update: if resource.data.id == visitId;
      allow read: if true;
    }
    
    // Coupons Collection (Partner Discounts)
    match /coupons/{code} {
      // Allow users to create a coupon document only once if it doesn't exist
      allow create: if !exists(/databases/$(database)/documents/coupons/$(code))
                    && request.resource.data.code == code
                    && request.resource.data.used == false;
      
      // Allow public reading of coupon status
      allow read: if true;
      
      // Allow updating ONLY to set used = true (redemption), blocking changing existing used coupons
      allow update: if resource.data.used == false 
                    && request.resource.data.used == true
                    && request.resource.data.usedAt != null;
    }
  }
}
